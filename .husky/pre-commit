# Check that package-lock.json exists for each app
echo "Checking package-lock.json files..."

if [ -f "apps/api/package.json" ] && [ ! -f "apps/api/package-lock.json" ]; then
  echo "Error: apps/api/package-lock.json is missing. Run 'npm install' in apps/api"
  exit 1
fi

if [ -f "apps/web/package.json" ] && [ ! -f "apps/web/package-lock.json" ]; then
  echo "Error: apps/web/package-lock.json is missing. Run 'npm install' in apps/web"
  exit 1
fi

# Run lint-staged
npx lint-staged

# Type check if any TypeScript files are staged
STAGED_TS_API=$(git diff --cached --name-only --diff-filter=ACM | grep "^apps/api/.*\.ts$" || true)
STAGED_TS_WEB=$(git diff --cached --name-only --diff-filter=ACM | grep "^apps/web/.*\.tsx\?$" || true)

if [ -n "$STAGED_TS_API" ]; then
  echo "Type checking API..."
  npm run type-check --prefix apps/api
  
  # Run only related tests for faster commits (full suite runs in CI)
  if npm run --prefix apps/api 2>/dev/null | grep -q "test"; then
    # Get staged API files as space-separated list (relative to apps/api)
    API_FILES=$(echo "$STAGED_TS_API" | sed 's|^apps/api/||' | tr '\n' ' ')
    
    if [ -n "$API_FILES" ]; then
      echo "Running related API tests for changed files..."
      # Jest --findRelatedTests runs only tests that cover the changed files
      cd apps/api && npx jest --findRelatedTests $API_FILES --passWithNoTests && cd ../..
    fi
  fi
fi

if [ -n "$STAGED_TS_WEB" ]; then
  echo "Type checking Web..."
  npm run type-check --prefix apps/web
  
  # Run only related tests for faster commits (full suite runs in CI)
  if npm run --prefix apps/web 2>/dev/null | grep -q "test"; then
    # Get staged Web files as space-separated list (relative to apps/web)
    WEB_FILES=$(echo "$STAGED_TS_WEB" | sed 's|^apps/web/||' | tr '\n' ' ')
    
    if [ -n "$WEB_FILES" ]; then
      echo "Running related Web tests for changed files..."
      # Vitest 'related' subcommand runs only tests related to the changed files
      cd apps/web && npx vitest related $WEB_FILES --run --passWithNoTests && cd ../..
    fi
  fi
fi
