# ===========================================
# Portfolio X-Ray API - Environment Variables
# ===========================================
# Copy this file to .env and update the values

# ===== Core Settings =====
NODE_ENV=development
PORT=4000

# ===== Database =====
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_xray?schema=public

# Connection Pool Settings (optional)
# DB_POOL_MAX=20
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=5000

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ===== External Services =====
# Morningstar base URL (usually doesn't need to be changed)
# MORNINGSTAR_BASE_URL=https://lt.morningstar.com

# ===== Cache Settings (optional) =====
# In-memory cache TTL in milliseconds (default: 5 minutes)
# CACHE_TTL_MS=300000
# Maximum items in cache
# CACHE_MAX_ITEMS=1000

# ===== Resolution Settings (optional) =====
# Max concurrent requests when batch resolving assets
# BATCH_CONCURRENCY_LIMIT=5
# Max number of alternatives to return
# MAX_ALTERNATIVES=5
# ISIN enrichment concurrency
# ISIN_ENRICHMENT_CONCURRENCY=5
# ISIN enrichment timeout in milliseconds
# ISIN_ENRICHMENT_TIMEOUT_MS=15000

# ===== HTTP Settings (optional) =====
# Default timeout for HTTP requests in milliseconds
# HTTP_DEFAULT_TIMEOUT_MS=10000

# ===== Circuit Breaker Settings (optional) =====
# Number of failures before opening the circuit
# CIRCUIT_FAILURE_THRESHOLD=5
# Time in ms to wait before attempting to close the circuit
# CIRCUIT_RESET_TIMEOUT_MS=30000
# Number of successes in half-open state before closing
# CIRCUIT_SUCCESS_THRESHOLD=2
