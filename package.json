{
  "name": "portfolio-xray",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio X-Ray Generator - Monorepo",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11"
  },
  "lint-staged": {
    "apps/api/**/*.{ts,tsx}": [
      "npm run lint --prefix apps/api"
    ],
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "npm run lint --prefix apps/web"
    ]
  }
}
